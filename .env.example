# Frontend environment. Copy to .env (or .env.local) and adjust.

# Base URL of the backend API.
# - Local dev (backend on :5000): leave as below.
# - Production (GitHub Pages): set to your hosted backend, e.g.
#   VITE_API_URL=https://mahabharat-api.onrender.com/api
VITE_API_URL=http://localhost:5000/api
