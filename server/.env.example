# Copy to .env and fill in. For local dev you can leave MONGODB_URI blank to
# auto-start an in-memory MongoDB (no install required).

PORT=5000
NODE_ENV=development

# Frontend origin allowed by CORS (Vite dev server / GitHub Pages URL).
CLIENT_URL=http://localhost:5180

# Leave blank for an auto in-memory DB in dev, or set your MongoDB Atlas URI:
# MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/mahabharat
MONGODB_URI=

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# File uploads
MAX_UPLOAD_MB=5
UPLOAD_DIR=uploads
# Cloudinary (free tier). If all three are set, uploads go to Cloudinary as
# private/authenticated assets; otherwise files are stored on local disk.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (Gmail SMTP) — sends a welcome email on signup.
# EMAIL_PASS must be a Gmail APP PASSWORD (Google Account > Security >
# 2-Step Verification > App passwords), NOT your normal Gmail password.
# Leave blank to disable email sending.
EMAIL_USER=info.mahabharatgroup@gmail.com
EMAIL_PASS=
EMAIL_FROM_NAME=Mahabharat Consultancy

# Masked-calling provider (Exotel / Twilio / Knowlarity) — Phase 5.
# Leave blank to use the safe built-in stub.
CALL_PROVIDER=stub
# EXOTEL_SID=
# EXOTEL_TOKEN=
# EXOTEL_CALLER_ID=
